local player = game.Players.LocalPlayer
local placeId = game.PlaceId

-- Danh sách ID bản đồ để tự động kích hoạt
local PVP_PLACE_IDS = {
    [5289429734] = true,
    [5480112241] = true,
    [4524359706] = true,
    [5468388011] = true,
    [3826587512] = true
}

-- URL mới của bạn
local BASE_URL = "https://raw.githubusercontent.com/longhazem/TOKAIHUB/refs/heads/main/RBM5PVP/Models/PvP"

local function loadRemoteScript()
    task.spawn(function()
        -- Thêm timestamp để tránh cache
        local success, result = pcall(function()
            return game:HttpGet(BASE_URL .. "?v=" .. tostring(os.time()))
        end)
        
        if success then
            loadstring(result)()
        else
            warn("Không thể tải script từ: " .. BASE_URL)
        end
    end)
end

-- Kiểm tra tự động nếu khớp ID thì chạy luôn
if PVP_PLACE_IDS[placeId] then
    loadRemoteScript()
    return
end

-- Nếu không khớp ID, hiện giao diện chọn thủ công
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TokaiHubSelection"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 300, 0, 150)
frame.Position = UDim2.new(0.5, -150, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 50)
title.BackgroundTransparency = 1
title.Text = "TOKAI HUB"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 20
title.Parent = frame

local loadButton = Instance.new("TextButton")
loadButton.Size = UDim2.new(0.8, 0, 0, 50)
loadButton.Position = UDim2.new(0.1, 0, 0.5, 0)
loadButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
loadButton.Text = "Load PvP Script"
loadButton.TextColor3 = Color3.fromRGB(255, 255, 255)
loadButton.Font = Enum.Font.GothamSemibold
loadButton.TextSize = 18
loadButton.Parent = frame

local bCorner = Instance.new("UICorner")
bCorner.CornerRadius = UDim.new(0, 8)
bCorner.Parent = loadButton

-- Xử lý khi bấm nút
loadButton.MouseButton1Click:Connect(function()
    loadButton.Text = "Loading..."
    loadButton.Active = false
    loadRemoteScript()
    task.wait(1)
    screenGui:Destroy()
end)
