local PVP = {}

-- Options
PVP.Options = {
    SilentAim    = false,
    WallCheck    = true,
    ShowFov      = false,
    FovRadius    = 50,
    ESP          = false,
    AimPart      = "Head",
    VisibleColor = Color3.fromRGB(0, 255, 0),
    HiddenColor  = Color3.fromRGB(255, 0, 0),
}

-- Raycast params builder
local function PVP_BuildRayParams()
    local p = RaycastParams.new()
    p.FilterType = Enum.RaycastFilterType.Blacklist
    local filter = { Camera }
    if Players.LocalPlayer.Character then
        table.insert(filter, Players.LocalPlayer.Character)
    end
    p.FilterDescendantsInstances = filter
    return p
end

-- Wall check: trả về true nếu part KHÔNG bị tường che
function PVP.IsPartVisible(part)
    if not part or not part.Parent then return false end
    local params  = PVP_BuildRayParams()
    local camPos  = Camera.CFrame.Position
    local dir     = part.Position - camPos
    local result  = workspace:Raycast(camPos, dir, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- FOV Circle (Drawing API)
local PVP_FovCircle = nil
pcall(function()
    PVP_FovCircle           = Drawing.new('Circle')
    PVP_FovCircle.Visible   = false
    PVP_FovCircle.Thickness = 1.5
    PVP_FovCircle.Color     = Color3.new(1, 1, 1)
    PVP_FovCircle.Filled    = false
end)

-- ESP tracking
local PVP_TrackedNPCs = {}

local function PVP_EnsureHighlight(model)
    if model:IsA("Model") and model.Name == "Male" then
        local hl = model:FindFirstChild("PVP_HL") or Instance.new("Highlight")
        hl.Name                = "PVP_HL"
        hl.FillTransparency    = 0.5
        hl.OutlineTransparency = 0
        hl.Enabled             = PVP.Options.ESP
        hl.Parent              = model
        PVP_TrackedNPCs[model] = hl
    end
end

-- RenderStepped: cập nhật FOV circle + ESP màu theo visibility
RunService.RenderStepped:Connect(function()
    if PVP_FovCircle then
        PVP_FovCircle.Position = Camera.ViewportSize / 2
        PVP_FovCircle.Radius   = PVP.Options.FovRadius
        PVP_FovCircle.Visible  = PVP.Options.ShowFov and PVP.Options.SilentAim
    end

    local rayParams = PVP_BuildRayParams()
    for model, hl in pairs(PVP_TrackedNPCs) do
        if not model or not model.Parent then
            PVP_TrackedNPCs[model] = nil; continue
        end
        hl.Enabled = PVP.Options.ESP
        if not PVP.Options.ESP then continue end
        local head = model:FindFirstChild("Head")
        if head then
            local camPos = Camera.CFrame.Position
            local result = workspace:Raycast(camPos, head.Position - camPos, rayParams)
            local isVis  = not result or result.Instance:IsDescendantOf(model)
            local col    = isVis and PVP.Options.VisibleColor or PVP.Options.HiddenColor
            hl.FillColor    = col
            hl.OutlineColor = col
        end
    end
end)

workspace.DescendantAdded:Connect(PVP_EnsureHighlight)
for _, v in pairs(workspace:GetDescendants()) do PVP_EnsureHighlight(v) end

-- Hook: Silent Aim + Recoil
local PVP_ClientService = nil

pcall(function()
    local PVP_Functions = {
        GetClients      = filtergc('function', {Name='GetClients', Constants={'Clients'}}, false),
        GetMuzzleCFrame = filtergc('function', {Name='GetMuzzleCFrame'}, true),
        GetRecoil       = filtergc('function', {Name='getRecoil'},       true),
    }

    -- Lấy ClientService thực
    for _, fn in pairs(PVP_Functions.GetClients) do
        local info = getinfo(fn)
        if info and info.source and not info.source:find('ClientService') then continue end
        local OldClients; OldClients = hookfunction(fn, function(self)
            PVP_ClientService = self
            return OldClients(self)
        end)
        break
    end

    local function PVP_GetActorPart(data)
        if not data or not data.Actor or not data.Actor.Parts then return nil end
        local parts = data.Actor.Parts
        return PVP.Options.AimPart == "Head"
            and parts.Head
            or  (parts.Torso or parts.UpperTorso or parts.HumanoidRootPart)
    end

    local function PVP_GetClosest()
        if not PVP_ClientService then return nil, nil end
        local best, bestData, bestDist = nil, nil, math.huge
        for player, data in pairs(PVP_ClientService.Clients) do
            if player == Players.LocalPlayer then continue end
            if not data.Actor or not data.Actor.Alive then continue end
            if data.Squad == PVP_ClientService.LocalClient.Squad then continue end
            local part = PVP_GetActorPart(data)
            if not part then continue end
            local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
            if not onScreen then continue end
            local d2D = (Vector2.new(sp.X, sp.Y) - Camera.ViewportSize/2).Magnitude
            if d2D > PVP.Options.FovRadius then continue end
            if PVP.Options.WallCheck and not PVP.IsPartVisible(part) then continue end
            if d2D < bestDist then best, bestData, bestDist = player, data, d2D end
        end
        return best, bestData
    end

    -- Expose GetClosest for external use (e.g. PVE module)
    PVP.GetClosest      = PVP_GetClosest
    PVP.GetActorPart    = PVP_GetActorPart

    local OldMuzzle; OldMuzzle = hookfunction(PVP_Functions.GetMuzzleCFrame, function(self, cast)
        local origin, barrel, cameraCF = OldMuzzle(self, cast)
        if PVP.Options.SilentAim and not cast and origin then
            local _, data = PVP_GetClosest()
            if data then
                local part = PVP_GetActorPart(data)
                if part then
                    return CFrame.new(origin.Position, part.Position), barrel, cameraCF
                end
            end
        end
        return origin, barrel, cameraCF
    end)

    local OldRecoil; OldRecoil = hookfunction(PVP_Functions.GetRecoil, function(...)
        local args = {...}
        if PVP.Options.SilentAim and args[1] then
            args[1]['Barrel_Spread']   = 0
            args[1]['RecoilForce_Tap'] = 0
        end
        return OldRecoil(table.unpack(args))
    end)
end)

