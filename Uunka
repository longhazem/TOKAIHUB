-- HÀM THÔNG BÁO CUSTOM
local function Notify(txt)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "YouTube Engine",
        Text = txt,
        Duration = 3
    })
end

-- HÀM TÌM KIẾM CHÍNH (Kết nối YouTube API Proxy)
local function SearchYouTube(query)
    -- Dọn dẹp kết quả cũ
    for _, item in pairs(Scroll:GetChildren()) do
        if item:IsA("Frame") then item:Destroy() end
    end

    Notify("Đang kết nối YouTube...")

    -- API Proxy mã nguồn mở (Piped API) - Rất ổn định cho Executor
    local apiUrl = "https://pipedapi.kavin.rocks/search?q=" .. HttpService:UrlEncode(query) .. "&filter=videos"

    local success, response = pcall(function()
        return game:HttpGet(apiUrl)
    end)

    if not success then
        Notify("Lỗi kết nối API!")
        return
    end

    local data = HttpService:JSONDecode(response)
    local results = data.content or {}

    if #results == 0 then
        Notify("Không tìm thấy kết quả.")
        return
    end

    for i, video in ipairs(results) do
        if i > 15 then break end -- Lấy tối đa 15 kết quả

        local ItemFrame = Instance.new("Frame")
        ItemFrame.Size = UDim2.new(1, -5, 0, 60)
        ItemFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        ItemFrame.Parent = Scroll

        local ICorn = Instance.new("UICorner")
        ICorn.CornerRadius = UDim.new(0, 6)
        ICorn.Parent = ItemFrame

        local VideoTitle = Instance.new("TextLabel")
        VideoTitle.Size = UDim2.new(1, -10, 0, 25)
        VideoTitle.Position = UDim2.new(0, 10, 0, 5)
        VideoTitle.BackgroundTransparency = 1
        VideoTitle.Text = video.title
        VideoTitle.TextColor3 = Color3.new(1, 1, 1)
        VideoTitle.TextSize = 14
        VideoTitle.Font = Enum.Font.GothamBold
        VideoTitle.TextXAlignment = Enum.TextXAlignment.Left
        VideoTitle.TextTruncate = Enum.TextTruncate.AtEnd
        VideoTitle.Parent = ItemFrame

        local Info = Instance.new("TextLabel")
        Info.Size = UDim2.new(1, -10, 0, 20)
        Info.Position = UDim2.new(0, 10, 0, 30)
        Info.BackgroundTransparency = 1
        Info.Text = "Kênh: " .. (video.uploaderName or "Unknown") .. " | Thời lượng: " .. (video.duration or "??")
        Info.TextColor3 = Color3.fromRGB(180, 180, 180)
        Info.TextSize = 12
        Info.Font = Enum.Font.Gotham
        Info.TextXAlignment = Enum.TextXAlignment.Left
        Info.Parent = ItemFrame

        local SelectBtn = Instance.new("TextButton")
        SelectBtn.Size = UDim2.new(1, 0, 1, 0)
        SelectBtn.BackgroundTransparency = 1
        SelectBtn.Text = ""
        SelectBtn.Parent = ItemFrame

        SelectBtn.MouseButton1Click:Connect(function()
            print("--- YOUTUBE DATA ---")
            print("Title: " .. video.title)
            print("ID: " .. video.videoId)
            print("URL: https://www.youtube.com/watch?v=" .. video.videoId)
            
            Notify("Đã lấy dữ liệu: " .. video.title)
            -- Ở đây bạn có thể thêm logic gửi dữ liệu này đi đâu tùy ý
        end)
    end
    
    Scroll.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
    Notify("Đã tìm thấy " .. #results .. " kết quả.")
end

-- Sự kiện khi gõ xong
SearchBox.FocusLost:Connect(function(enter)
    if enter and SearchBox.Text ~= "" then
        SearchYouTube(SearchBox.Text)
    end
end)
